<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<ScrollPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="ui.controllers.HomeController"
            fitToWidth="true" fitToHeight="true"
            hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
            styleClass="scroll-pane">

    <VBox alignment="CENTER" spacing="0">

        <!-- ═══ Hero Section ═══ -->
        <VBox styleClass="hero-section" alignment="CENTER" spacing="16" minHeight="480">
            <padding><Insets top="80" right="60" bottom="40" left="60"/></padding>

            <Label fx:id="heroTitle" text="CIPHERFORGE" styleClass="heading-massive"/>
            <Label fx:id="heroSubtitle" text="ENCRYPTION  •  PRECISION  •  SECURITY" styleClass="text-subtitle"/>

            <Region prefHeight="40"/>

            <Label fx:id="scrollPrompt" text="↓  EXPLORE TOOLS  ↓" styleClass="scroll-prompt"/>
        </VBox>

        <!-- ═══ Project Cards Section ═══ -->
        <VBox spacing="0">
            <padding><Insets top="0" right="40" bottom="60" left="40"/></padding>

            <!-- Section divider -->
            <HBox alignment="CENTER_LEFT" spacing="16">
                <padding><Insets top="40" right="20" bottom="24" left="20"/></padding>
                <Label text="TOOLS" styleClass="heading-section"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="SELECT A TOOL TO BEGIN" styleClass="text-caption"/>
            </HBox>

            <!-- Horizontal card row -->
            <HBox fx:id="cardContainer" spacing="20" alignment="CENTER">
                <padding><Insets top="8" right="0" bottom="20" left="0"/></padding>

                <!-- Card 01: Encrypt / Decrypt -->
                <VBox styleClass="studio-card" spacing="12" prefWidth="320" prefHeight="340"
                      onMouseClicked="#onCardEncrypt" HBox.hgrow="ALWAYS">
                    <padding><Insets top="28" right="28" bottom="28" left="28"/></padding>
                    <Label text="01" styleClass="card-index"/>
                    <Region VBox.vgrow="ALWAYS"/>
                    <Label text="ENCRYPT / DECRYPT" styleClass="card-title-studio"/>
                    <Label text="Transform text using AES, Blowfish, or Caesar cipher with full key management." styleClass="card-desc" wrapText="true"/>
                </VBox>

                <!-- Card 02: File Operations -->
                <VBox styleClass="studio-card" spacing="12" prefWidth="320" prefHeight="340"
                      onMouseClicked="#onCardFiles" HBox.hgrow="ALWAYS">
                    <padding><Insets top="28" right="28" bottom="28" left="28"/></padding>
                    <Label text="02" styleClass="card-index"/>
                    <Region VBox.vgrow="ALWAYS"/>
                    <Label text="FILE OPERATIONS" styleClass="card-title-studio"/>
                    <Label text="Load, encrypt, decrypt, and save entire files with a single action." styleClass="card-desc" wrapText="true"/>
                </VBox>

                <!-- Card 03: Settings -->
                <VBox styleClass="studio-card" spacing="12" prefWidth="320" prefHeight="340"
                      onMouseClicked="#onCardSettings" HBox.hgrow="ALWAYS">
                    <padding><Insets top="28" right="28" bottom="28" left="28"/></padding>
                    <Label text="03" styleClass="card-index"/>
                    <Region VBox.vgrow="ALWAYS"/>
                    <Label text="SETTINGS" styleClass="card-title-studio"/>
                    <Label text="Configure default algorithms, themes, and application preferences." styleClass="card-desc" wrapText="true"/>
                </VBox>

            </HBox>
        </VBox>

    </VBox>

</ScrollPane>
