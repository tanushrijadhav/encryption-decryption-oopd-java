<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="ui.controllers.SettingsController"
      spacing="24" styleClass="settings-view">

    <!-- Appearance -->
    <VBox styleClass="card" spacing="16">
        <padding><Insets top="24" right="28" bottom="24" left="28"/></padding>
        <Label text="Appearance" styleClass="card-title"/>
        <Separator styleClass="card-separator"/>
        <HBox alignment="CENTER_LEFT" spacing="16">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="Theme" styleClass="setting-label"/>
                <Label text="Switch between light and dark mode" styleClass="setting-description"/>
            </VBox>
            <ToggleButton fx:id="settingsThemeToggle" styleClass="theme-switch" onAction="#onToggleTheme" selected="true"/>
        </HBox>
        <HBox alignment="CENTER_LEFT" spacing="16">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="Default Algorithm" styleClass="setting-label"/>
                <Label text="Algorithm selected by default on encryption page" styleClass="setting-description"/>
            </VBox>
            <ComboBox fx:id="defaultAlgoCombo" styleClass="algo-combo" prefWidth="180" promptText="Select..."/>
        </HBox>
    </VBox>

    <!-- About -->
    <VBox styleClass="card" spacing="16">
        <padding><Insets top="24" right="28" bottom="24" left="28"/></padding>
        <Label text="About CipherForge" styleClass="card-title"/>
        <Separator styleClass="card-separator"/>
        <HBox alignment="CENTER_LEFT" spacing="16">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="Version" styleClass="setting-label"/>
                <Label text="Current application version" styleClass="setting-description"/>
            </VBox>
            <Label text="1.0.0" styleClass="version-badge"/>
        </HBox>
        <HBox alignment="CENTER_LEFT" spacing="16">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="Team" styleClass="setting-label"/>
                <Label text="Built with OOP principles by TJ, TG, AG" styleClass="setting-description"/>
            </VBox>
        </HBox>
        <HBox alignment="CENTER_LEFT" spacing="16">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="Architecture" styleClass="setting-label"/>
                <Label text="Strategy Pattern &#x2022; MVC &#x2022; Composition" styleClass="setting-description"/>
            </VBox>
        </HBox>
    </VBox>
</VBox>
