<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="ui.controllers.MainController"
            styleClass="root-pane"
            prefWidth="1280" prefHeight="800">

    <!-- SIDEBAR -->
    <left>
        <VBox styleClass="sidebar" spacing="0">
            <!-- Logo -->
            <HBox styleClass="sidebar-logo" alignment="CENTER_LEFT" spacing="12">
                <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>
                <Label text="&#x2B21;" styleClass="logo-icon"/>
                <VBox spacing="2">
                    <Label text="CipherForge" styleClass="logo-text"/>
                    <Label text="Encryption Suite" styleClass="logo-subtitle"/>
                </VBox>
            </HBox>

            <Separator styleClass="sidebar-separator"/>

            <!-- Navigation -->
            <VBox styleClass="nav-container" spacing="4">
                <padding><Insets top="16" right="12" bottom="16" left="12"/></padding>
                <Label text="MAIN MENU" styleClass="nav-section-label"/>

                <HBox fx:id="navDashboard" styleClass="nav-item,nav-item-active" alignment="CENTER_LEFT" spacing="12" onMouseClicked="#onNavDashboard">
                    <padding><Insets top="10" right="16" bottom="10" left="16"/></padding>
                    <Label text="&#x25C9;" styleClass="nav-icon"/>
                    <Label text="Dashboard" styleClass="nav-label"/>
                </HBox>

                <HBox fx:id="navEncrypt" styleClass="nav-item" alignment="CENTER_LEFT" spacing="12" onMouseClicked="#onNavEncrypt">
                    <padding><Insets top="10" right="16" bottom="10" left="16"/></padding>
                    <Label text="&#x229E;" styleClass="nav-icon"/>
                    <Label text="Encrypt / Decrypt" styleClass="nav-label"/>
                </HBox>

                <HBox fx:id="navFiles" styleClass="nav-item" alignment="CENTER_LEFT" spacing="12" onMouseClicked="#onNavFiles">
                    <padding><Insets top="10" right="16" bottom="10" left="16"/></padding>
                    <Label text="&#x2B1A;" styleClass="nav-icon"/>
                    <Label text="File Operations" styleClass="nav-label"/>
                </HBox>

                <HBox fx:id="navSettings" styleClass="nav-item" alignment="CENTER_LEFT" spacing="12" onMouseClicked="#onNavSettings">
                    <padding><Insets top="10" right="16" bottom="10" left="16"/></padding>
                    <Label text="&#x2699;" styleClass="nav-icon"/>
                    <Label text="Settings" styleClass="nav-label"/>
                </HBox>
            </VBox>

            <!-- Spacer -->
            <Region VBox.vgrow="ALWAYS"/>

            <!-- Bottom: Theme Toggle -->
            <VBox spacing="8">
                <padding><Insets top="16" right="16" bottom="24" left="16"/></padding>
                <Separator styleClass="sidebar-separator"/>
                <HBox alignment="CENTER_LEFT" spacing="12" styleClass="theme-toggle-container">
                    <padding><Insets top="12" right="8" bottom="8" left="8"/></padding>
                    <Label text="&#x25D0;" styleClass="nav-icon"/>
                    <Label text="Dark Mode" styleClass="nav-label" fx:id="themeLabel"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <ToggleButton fx:id="themeToggle" styleClass="theme-switch" onAction="#onThemeToggle" selected="true"/>
                </HBox>
            </VBox>
        </VBox>
    </left>

    <!-- CENTER: Top bar + Content -->
    <center>
        <VBox styleClass="main-area">
            <!-- Top Bar -->
            <HBox styleClass="top-bar" alignment="CENTER" spacing="16">
                <padding><Insets top="16" right="32" bottom="16" left="32"/></padding>
                <VBox spacing="2">
                    <Label fx:id="pageTitle" text="Dashboard" styleClass="page-title"/>
                    <Label fx:id="pageSubtitle" text="Overview of your encryption activity" styleClass="page-subtitle"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <TextField fx:id="searchField" promptText="Search..." styleClass="search-field" prefWidth="220"/>
                <Separator orientation="VERTICAL" styleClass="topbar-separator"/>
                <HBox alignment="CENTER" spacing="10" styleClass="profile-section">
                    <Label text="&#x2295;" styleClass="notification-icon"/>
                    <StackPane styleClass="avatar">
                        <Label text="AG" styleClass="avatar-text"/>
                    </StackPane>
                </HBox>
            </HBox>

            <!-- Content Area -->
            <StackPane fx:id="contentArea" VBox.vgrow="ALWAYS" styleClass="content-area">
                <padding><Insets top="24" right="32" bottom="24" left="32"/></padding>
            </StackPane>
        </VBox>
    </center>
</BorderPane>
