<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<!-- Split-screen layout: decorative left + settings right -->
<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="ui.controllers.SettingsController"
      spacing="0">

    <!-- ═══ Left: Decorative Panel ═══ -->
    <VBox styleClass="split-left" alignment="BOTTOM_LEFT" spacing="8">
        <padding><Insets top="40" right="32" bottom="40" left="32"/></padding>

        <Label text="03" styleClass="decorative-number"/>
        <Label text="SETTINGS" styleClass="view-title"/>
        <Region prefHeight="16"/>
        <Label text="Configure your application preferences, default algorithms, and visual theme." styleClass="view-desc"/>
    </VBox>

    <!-- ═══ Right: Settings Panel ═══ -->
    <VBox styleClass="split-right" HBox.hgrow="ALWAYS" spacing="24">
        <padding><Insets top="40" right="48" bottom="40" left="48"/></padding>

        <!-- Appearance Section -->
        <VBox styleClass="settings-section" spacing="20">
            <Label text="APPEARANCE" styleClass="heading-card"/>

            <HBox alignment="CENTER_LEFT" spacing="16">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Theme" styleClass="setting-label"/>
                    <Label text="Toggle between light and dark mode" styleClass="setting-description"/>
                </VBox>
                <ToggleButton fx:id="settingsThemeToggle" text="DARK" styleClass="theme-switch" onAction="#onToggleTheme" selected="false"/>
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="16">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Default Algorithm" styleClass="setting-label"/>
                    <Label text="Algorithm selected by default on encryption page" styleClass="setting-description"/>
                </VBox>
                <ComboBox fx:id="defaultAlgoCombo" styleClass="studio-combo" prefWidth="200" promptText="Select..."/>
            </HBox>
        </VBox>

        <!-- About Section -->
        <VBox styleClass="settings-section" spacing="20">
            <Label text="ABOUT CIPHERFORGE" styleClass="heading-card"/>

            <HBox alignment="CENTER_LEFT" spacing="16">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Version" styleClass="setting-label"/>
                    <Label text="Current application version" styleClass="setting-description"/>
                </VBox>
                <Label text="v1.0.0" styleClass="version-badge"/>
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="16">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Team" styleClass="setting-label"/>
                    <Label text="Built with OOP principles by TJ, TG, AG" styleClass="setting-description"/>
                </VBox>
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="16">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Architecture" styleClass="setting-label"/>
                    <Label text="Strategy Pattern • MVC • Composition" styleClass="setting-description"/>
                </VBox>
            </HBox>
        </VBox>

    </VBox>

</HBox>
