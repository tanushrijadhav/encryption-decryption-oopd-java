<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="ui.controllers.DashboardController"
      spacing="24" styleClass="dashboard-view">

    <!-- KPI Cards Row -->
    <HBox spacing="20" styleClass="kpi-row">
        <VBox HBox.hgrow="ALWAYS" styleClass="kpi-card" spacing="8">
            <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>
            <HBox alignment="CENTER_LEFT" spacing="12">
                <StackPane styleClass="kpi-icon-container,kpi-icon-blue"><Label text="&#x1F510;" styleClass="kpi-icon"/></StackPane>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="&#x2191; 12%" styleClass="kpi-trend-up"/>
            </HBox>
            <Label fx:id="totalOpsValue" text="1,284" styleClass="kpi-value"/>
            <Label text="Total Operations" styleClass="kpi-label"/>
        </VBox>

        <VBox HBox.hgrow="ALWAYS" styleClass="kpi-card" spacing="8">
            <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>
            <HBox alignment="CENTER_LEFT" spacing="12">
                <StackPane styleClass="kpi-icon-container,kpi-icon-green"><Label text="&#x2713;" styleClass="kpi-icon"/></StackPane>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="99.2%" styleClass="kpi-trend-up"/>
            </HBox>
            <Label fx:id="successValue" text="1,274" styleClass="kpi-value"/>
            <Label text="Successful" styleClass="kpi-label"/>
        </VBox>

        <VBox HBox.hgrow="ALWAYS" styleClass="kpi-card" spacing="8">
            <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>
            <HBox alignment="CENTER_LEFT" spacing="12">
                <StackPane styleClass="kpi-icon-container,kpi-icon-purple"><Label text="&#x26A1;" styleClass="kpi-icon"/></StackPane>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="AES-CBC" styleClass="kpi-badge"/>
            </HBox>
            <Label fx:id="activeAlgoValue" text="AES" styleClass="kpi-value"/>
            <Label text="Active Algorithm" styleClass="kpi-label"/>
        </VBox>

        <VBox HBox.hgrow="ALWAYS" styleClass="kpi-card" spacing="8">
            <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>
            <HBox alignment="CENTER_LEFT" spacing="12">
                <StackPane styleClass="kpi-icon-container,kpi-icon-amber"><Label text="&#x2298;" styleClass="kpi-icon"/></StackPane>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="&#x2193; 3%" styleClass="kpi-trend-down"/>
            </HBox>
            <Label fx:id="failedValue" text="10" styleClass="kpi-value"/>
            <Label text="Failed" styleClass="kpi-label"/>
        </VBox>
    </HBox>

    <!-- Charts + Activity Row -->
    <HBox spacing="20" VBox.vgrow="ALWAYS">
        <VBox HBox.hgrow="ALWAYS" styleClass="card" spacing="16">
            <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>
            <HBox alignment="CENTER_LEFT">
                <Label text="Algorithm Usage" styleClass="card-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="Last 30 days" styleClass="card-subtitle-badge"/>
            </HBox>
            <HBox spacing="16" alignment="BOTTOM_CENTER" VBox.vgrow="ALWAYS">
                <padding><Insets top="16" bottom="8"/></padding>
                <VBox alignment="BOTTOM_CENTER" spacing="6">
                    <Region styleClass="bar-chart-bar,bar-blue" prefWidth="48" prefHeight="140"/>
                    <Label text="AES" styleClass="bar-label"/>
                </VBox>
                <VBox alignment="BOTTOM_CENTER" spacing="6">
                    <Region styleClass="bar-chart-bar,bar-purple" prefWidth="48" prefHeight="90"/>
                    <Label text="Caesar" styleClass="bar-label"/>
                </VBox>
                <VBox alignment="BOTTOM_CENTER" spacing="6">
                    <Region styleClass="bar-chart-bar,bar-indigo" prefWidth="48" prefHeight="55"/>
                    <Label text="Blowfish" styleClass="bar-label"/>
                </VBox>
            </HBox>
        </VBox>

        <VBox HBox.hgrow="ALWAYS" styleClass="card" spacing="16">
            <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>
            <HBox alignment="CENTER_LEFT">
                <Label text="Recent Activity" styleClass="card-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="View All" styleClass="card-link"/>
            </HBox>
            <VBox spacing="0" fx:id="activityList" VBox.vgrow="ALWAYS" styleClass="activity-list"/>
        </VBox>
    </HBox>
</VBox>
